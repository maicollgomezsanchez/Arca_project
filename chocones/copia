                                size: self.size
                                pos: self.pos
                                radius: [radius_default]
                        on_release: self.canvas.before.children[0].rgba = utils.get_color_from_hex(color_btn_normal)
                        on_press: self.canvas.before.children[0].rgba = utils.get_color_from_hex(color_btn_press)
