#:import Factory kivy.factory.Factory
#:import get_color_from_hex kivy.utils.get_color_from_hex

#:set lvolver "VOLVER"
#:set leventos "VER EVENTOS"
#:set lexportar "EXPORTAR EVENTOS"
#:set leliminar "ELIMINAR"


<Button>
    background_color: get_color_from_hex("#fff700")

# ---------------------------------------------------
# POPUP REUTILIZABLE
# ---------------------------------------------------
<ReusablePopup>:
    title: root.title_text
    size_hint: .6, .4
    auto_dismiss: False

    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 20

        Label:
            text: root.message
            font_size: 20
            halign: "center"
            valign: "middle"
            text_size: self.width, self.height
            size_hint_y: 0.5

        BoxLayout:
            orientation: "horizontal"
            spacing: 20
            size_hint_y: 0.5

            Button:
                text: "NO"
                size_hint_x: 1
                opacity: 1 if root.confirm_mode else 0
                disabled: not root.confirm_mode
                on_release: root.dismiss()

            Button:
                text: "ELIMINAR" if root.confirm_mode else "OK"
                size_hint_x: 1
                on_release:
                    root.dismiss()
                    if root.on_confirm: root.on_confirm()

# ---------------------------------------------------
# GESTOR DE PANTALLAS
# ---------------------------------------------------
ScreenManager:
    MainScreen:
        name: "main"
    FileListScreen:
        name: "file_list"
    FileViewerScreen:
        name: "file_viewer"

# ---------------------------------------------------
# PANTALLA PRINCIPAL
# ---------------------------------------------------
<MainScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, .30
        Rectangle:
            pos: self.pos
            size: self.size
            source: "fondo.jpeg"

    BoxLayout:
        orientation: "horizontal"
        padding: 20
        spacing: 20

        BoxLayout:
            orientation: "vertical"
            size_hint_x: 0.75

            Widget:
                size_hint_y: 0.1

            BoxLayout:
                size_hint_y: 0.8
                padding: dp(10)

                SpeedMeter:
                    id: speed
                    max: 120
                    tick: 10
                    start_angle: -120
                    end_angle: 120
                    display_first: False
                    display_last: False
                    subtick: 5
                    label_font_size: 30
                    label: str(int(root.speed)) + ' Km/h'
                    value: root.speed
                    cadran_color: get_color_from_hex("#000000")
                    sectors: (0, "#ffffff")
                    needle_color: get_color_from_hex("#ff0000")

        BoxLayout:
            orientation: "vertical"
            size_hint_x: 0.25
            padding: 10
            spacing: 10

            BoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                spacing: 10

            #Button:
            #    text: "Pulsos"
            #    size_hint_x: None
            #    width: dp(150)
            #    on_release:
            #        root.simular_pulso()

            Widget:
                size_hint_y: 1

            Button:
                text: leventos
                size_hint_y: None
                height: dp(50)
                on_release:
                    root.nextPage = True
                    root.close_and_save_file()
                    app.root.current = "file_list"

# ---------------------------------------------------
# PANTALLA LISTA DE ARCHIVOS
# ---------------------------------------------------
<FileListScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, .30
        Rectangle:
            pos: self.pos
            size: self.size
            source: "fondo.jpeg"

    BoxLayout:
        orientation: "horizontal"
        padding: 20
        spacing: 20

        BoxLayout:
            orientation: "vertical"
            size_hint_x: 0.75

            Label:
                text: "Archivos disponibles"
                font_size: 28
                size_hint_y: 0.1

            ScrollView:
                size_hint_y: 0.9

                GridLayout:
                    id: file_list
                    cols: 1
                    spacing: 10
                    size_hint_y: None
                    height: self.minimum_height

        BoxLayout:
            orientation: "vertical"
            size_hint_x: 0.25
            padding: 10
            spacing: 10

            BoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                spacing: 10

                Button:
                    text: lexportar
                    size_hint_y: None
                    height: 50
                    on_release: root.exportar_todos_usb()

                Button:
                    text: leliminar
                    size_hint_y: None
                    height: 50
                    on_release: root.borrar_archivos()

            Widget:
                size_hint_y: 1

            Button:
                text: lvolver
                size_hint_y: None
                height: 50
                on_release: app.root.current = "main"

# ---------------------------------------------------
# PANTALLA VISOR DE ARCHIVOS
# ---------------------------------------------------
<FileViewerScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, .30
        Rectangle:
            pos: self.pos
            size: self.size
            source: "fondo.jpeg"

    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 20

        Label:
            text: root.filename_open
            font_size: 32
            size_hint_y: None
            height: 60
            halign: "center"
            valign: "middle"
            text_size: self.size

        ScrollView:
            size_hint_y: 1

            Label:
                text: root.content
                font_size: 25
                color: 0,0,0,1
                text_size: self.width, None
                size_hint_y: None
                height: self.texture_size[1]

                canvas.before:
                    Color:
                        rgba: 1, 1, 1, 0.75
                    Rectangle:
                        pos: self.pos
                        size: self.size

        BoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: 60

            Widget:

            Button:
                text: lvolver
                size_hint_x: .25
                width: 150
                on_release: app.root.current = "file_list"
