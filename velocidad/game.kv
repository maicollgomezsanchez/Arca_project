#:kivy 2.1.0

#:set lvolver "VOLVER"
#:set leventos "VER EVENTOS"
#:set lexportar "EXPORTAR EVENTOS"
#:set leliminar "ELIMINAR"

<ReusablePopup>:
    title: root.title_text
    size_hint: .6, .4
    auto_dismiss: False

    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 20

        Label:
            text: root.message
            font_size: 20
            halign: "center"
            valign: "middle"
            text_size: self.width, self.height
            size_hint_y: 0.5

        BoxLayout:
            orientation: "horizontal"
            spacing: 20
            size_hint_y: 0.5

            Button:
                text: "NO"
                size_hint_x: 1
                opacity: 1 if root.confirm_mode else 0
                disabled: not root.confirm_mode
                on_release: root.dismiss()

            Button:
                text: "ELIMINAR" if root.confirm_mode else "OK"
                size_hint_x: 1
                on_release:
                    root.dismiss()
                    if root.on_confirm: root.on_confirm()

ScreenManager:
    MainScreen:
        name: "main"
    FileListScreen:
        name: "file_list"
    FileViewerScreen:
        name: "file_viewer"


<MainScreen>:
    canvas.before:
        # Capa blanca semitransparente (primero)
        Color:
            rgba: 1, 1, 1, .5

        Rectangle:
            pos: self.pos
            size: self.size
            source: "fondo.jpeg"

    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 20

        Label:
            text: "Velocidad: " + str(root.speed) + " km/h"
            font_size: 40
            size_hint_y: 0.5

        Label:
            text: "Archivo activo: " + root.active_file
            font_size: 18
            size_hint_y: 0.15

        Button:
            text: leventos
            size_hint_y: 0.15
            on_release: root.close_and_save_file(); app.root.current = "file_list"


<FileListScreen>:

    canvas.before:
        Color:
            rgba: 1, 1, 1, .30
        Rectangle:
            pos: self.pos
            size: self.size
            source: "fondo.jpeg"
    
    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 10

        Label:
            text: "Archivos disponibles"
            font_size: 28
            size_hint_y: 0.1

        ScrollView:
            size_hint_y: 0.8

            GridLayout:
                id: file_list
                cols: 1
                spacing: 10
                size_hint_y: None
                height: self.minimum_height

        Button:
            text: lexportar
            size_hint_y: 0.15
            on_release: root.exportar_todos_usb()
        Button:
            text: leliminar
            size_hint_y: 0.15
            on_release: root.borrar_archivos()
        Button:
            text: lvolver
            size_hint_y: 0.15
            on_release: app.root.current = "main"


<FileViewerScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, .30
        Rectangle:
            pos: self.pos
            size: self.size
            source: "fondo.jpeg"

    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 10

        Label:
            text: root.filename_open
            font_size: 30
            size_hint_y: 0.1

        ScrollView:
            size_hint_y: 0.75

            Label:
                text: root.content
                font_size: 25
                text_size: self.width, None
                size_hint_y: None
                height: self.texture_size[1]

        Button:
            text: lvolver
            size_hint_y: 0.15
            on_release: app.root.current = "file_list"
