#:kivy 2.3.0

<ReusablePopup>:
    title_text: ""
    message: ""

<ReusablePopup@Popup>:
    title: root.title_text   # ← ENLACE CORRECTO
    message: ""
    size_hint: .6, .4
    auto_dismiss: False

    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 20

        Label:
            text: root.message
            font_size: 20
            halign: "center"
            valign: "middle"
            text_size: self.width, None

        Button:
            text: "OK"
            size_hint_y: 0.3
            on_release: root.dismiss()


ScreenManager:
    MainScreen:
        name: "main"
    FileListScreen:
        name: "file_list"
    FileViewerScreen:
        name: "file_viewer"


<MainScreen>:
    canvas.before:
        # Capa blanca semitransparente (primero)
        Color:
            rgba: 1, 1, 1, .50

        # Fondo (después)
        Rectangle:
            pos: self.pos
            size: self.size
            source: "fondo.jpeg"

    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 20

        Label:
            text: "Velocidad: " + str(root.speed) + " km/h"
            font_size: 40
            size_hint_y: 0.2

        Label:
            text: "Archivo activo: " + root.active_file
            font_size: 18
            size_hint_y: 0.1

        Button:
            id: stop_button
            text: "Simular pulso"
            size_hint_y: 0.15

        Button:
            text: "Ver archivos"
            size_hint_y: 0.15
            on_release: root.close_and_save_file(); app.root.current = "file_list"


<FileListScreen>:

    canvas.before:
        Color:
            rgba: 1, 1, 1, .50
        Rectangle:
            pos: self.pos
            size: self.size
            source: "fondo.jpeg"
    
    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 10

        Label:
            text: "Archivos disponibles"
            font_size: 28
            size_hint_y: 0.1

        ScrollView:
            size_hint_y: 0.8

            GridLayout:
                id: file_list
                cols: 1
                spacing: 10
                size_hint_y: None
                height: self.minimum_height

        Button:
            text: "EXPORTAR ARCHIVOS"
            size_hint_y: 0.1
            on_release: root.exportar_todos_usb()
        Button:
            text: "ELIMINAR ARCHIVOS"
            size_hint_y: 0.1
            on_release: root.borrar_archivos()
        Button:
            text: "VOLVER"
            size_hint_y: 0.1
            on_release: app.root.current = "main"



<FileViewerScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, .25   # negro semitransparente
        Rectangle:
            pos: self.pos
            size: self.size
            source: "fondo.jpeg"

    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 10

        Label:
            text: "Contenido del archivo"
            font_size: 28
            size_hint_y: 0.1

        ScrollView:
            size_hint_y: 0.8

            Label:
                text: root.content
                font_size: 18
                text_size: self.width, None
                size_hint_y: None
                height: self.texture_size[1]

        Button:
            text: "Volver"
            size_hint_y: 0.1
            on_release: app.root.current = "file_list"
