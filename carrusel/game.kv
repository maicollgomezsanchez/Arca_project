#:kivy 2.2.1
#:import utils kivy.utils

############ CONSTANTES #########
#:set radius_default 25
#:set color_fondo_pantalla '#cee5e5'
#:set color_btn_press '#aeaeae'
#:set color_btn_normal '#90a4a4'

# ------------------------
# ESTILOS GENERALES
# ------------------------

<BoxLayout>:
    spacing: 15

<Label>:
    font_size: 36
    halign: 'center'
    valign: 'middle'
    color: (0,0,0,1)

<Button>:
    font_size: 24
    color: (0,0,0,1)
    background_color: (0,0,0,0)

    canvas.before:
        Color:
            rgba: utils.get_color_from_hex(color_btn_press) if self.state == 'down' else utils.get_color_from_hex(color_btn_normal)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [radius_default]

<ToggleButton>:
    font_size: 24
    color: (0,0,0,1)
    background_color: (0,0,0,0)

    canvas.before:
        Color:
            rgba: utils.get_color_from_hex(color_btn_press) if self.state == 'down' else utils.get_color_from_hex(color_btn_normal)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [radius_default]

# ------------------------
# ROOT
# ------------------------

ScreenManager:
    MainScreen:
        name: "main"

# ------------------------
# MAIN SCREEN
# ------------------------

<MainScreen>:

    canvas.before:
        Color:
            rgba: utils.get_color_from_hex(color_fondo_pantalla)
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'horizontal'

        # ✅ COLUMNA IZQUIERDA (DINÁMICA)
        ScreenManager:
            id: left_manager
            size_hint_x: 0.7

            # ------------------------
            # PANTALLA MODOS
            # ------------------------
            Screen:
                name: "modes"

                BoxLayout:
                    orientation: "vertical"

                    Button:
                        text: "MANUAL"
                        on_press: root.go_mode("MANUAL")

                    Button:
                        text: "SEMI"
                        on_press: root.go_mode("SEMI")

                    Button:
                        text: "AUTO"
                        on_press: root.go_mode("AUTO")

            # ------------------------
            # PANTALLA CONFIG
            # ------------------------
            Screen:
                name: "config"

                BoxLayout:
                    orientation: "vertical"

                    # ✅ CONTENEDOR DINÁMICO
                    BoxLayout:
                        id: time_container
                        orientation: "vertical"

                        Label:
                            text: "Configurar tiempos"

                    # ✅ CONTROLES
                    BoxLayout:
                        size_hint_y: 0.3

                        ToggleButton:
                            text: "MARCHA"
                            on_press: root.start()

                        ToggleButton:
                            text: "PAUSA"
                            on_press: root.pause()

                        Button:
                            text: "VOLVER"
                            on_press: root.go_back()

        # ✅ COLUMNA DERECHA FIJA
        BoxLayout:
            orientation: "vertical"
            size_hint_x: 0.3

            ToggleButton:
                id: decoin_button
                text: "ACTIVAR\nDESCARGA"
                on_press: root.decoin_press()

            Button:
                id: coin_button
                text: "COMER\nFICHAS"
                on_press: root.special_buttons("coin")

            Button:
                text: "BOCINA"
                on_press: root.special_buttons("buzzer")
                on_release: root.off_buzzer()

            Button:
                text: "PARO"
                on_press: root.state_press("STOP", "normal")